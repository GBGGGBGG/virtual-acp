# GateX production environment template
# Copy to .env on deployment host and replace all placeholder values.

PORT=8787

# Redis (required for production)
REDIS_URL=redis://<redis-host>:6379
REDIS_KEY_PREFIX=gatex-prod
REDIS_STATE_TTL_SEC=86400

# REQUIRED: set strong random secrets (do not keep defaults)
GATEX_SIGNING_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
GATEX_ADMIN_TOKEN=REPLACE_WITH_LONG_RANDOM_ADMIN_TOKEN_MIN_32_CHARS

# Logging
GATEX_LOG_DIR=./logs

# Optional hardening (if used in your runtime/proxy)
# NODE_ENV=production
