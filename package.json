{
  "name": "gatex-acp",
  "version": "0.1.0",
  "private": true,
  "description": "GateX ACP - Adaptive Deterministic Risk Operating System",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test",
    "preflight": "node scripts/preflight.js",
    "smoke": "node scripts/smoke.js",
    "simulate:historical": "node scripts/simulate-historical.js",
    "benchmark": "node scripts/benchmark.js",
    "benchmark:summary": "node scripts/benchmark-aggregate.js --mode external --limit 3",
    "case-study:synthetic": "node scripts/case-study-synthetic.js",
    "bundle": "bash scripts/build-deployment-bundle.sh",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "express": "^4.21.2",
    "ioredis": "^5.6.1",
    "zod": "^3.23.8"
  }
}